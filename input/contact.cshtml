Title: Contact
Description: Get in touch.
---
@{
    var email = Document.GetString("SiteEmail", "");
    var linkedIn = Document.GetString("LinkedInUrl", "");
}

<section class="hero">
    <p class="hero__kicker">Contact</p>
    <h1 class="hero__name">Get in touch</h1>
    <p class="hero__tagline">
        Have a question, an opportunity, or just want to say hello? Send a note below.
    </p>
</section>

<section class="section">
    <div class="contact-grid">
        <form id="contact-form" novalidate>
            <div class="field">
                <label for="cf-name">Your name</label>
                <input id="cf-name" name="name" type="text" autocomplete="name" required />
            </div>
            <div class="field">
                <label for="cf-email">Email</label>
                <input id="cf-email" name="email" type="email" autocomplete="email" required />
            </div>
            <div class="field">
                <label for="cf-message">Message</label>
                <textarea id="cf-message" name="message" required></textarea>
            </div>
            <button class="btn" type="submit" id="cf-submit">Send message</button>
            <p class="form-note" id="cf-note" role="status" aria-live="polite"></p>
        </form>

        <div class="prose">
            <p>Prefer something direct?</p>
            <ul>
                @if (!string.IsNullOrWhiteSpace(email)) { <li>Email: <a href="mailto:@email">@email</a></li> }
                @if (!string.IsNullOrWhiteSpace(linkedIn)) { <li>LinkedIn: <a href="@linkedIn" target="_blank" rel="noopener">Connect</a></li> }
            </ul>
        </div>
    </div>
</section>

<script src="/assets/js/site.js" defer></script>
